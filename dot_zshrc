# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Explicitly define ZSH_CUSTOM for Chezmoi-managed custom configurations
export ZSH_CUSTOM="$HOME/.oh-my-zsh/custom"

# Set theme to Powerlevel10k
ZSH_THEME="powerlevel10k/powerlevel10k"

# Recommended Oh-My-Zsh Settings
HYPHEN_INSENSITIVE="true"             # _ and - are interchangeable
zstyle ':omz:update' mode auto        # update automatically without asking
COMPLETION_WAITING_DOTS="true"        # display red dots whilst waiting for completion
HIST_STAMPS="yyyy-mm-dd"              # command execution time stamp in history

# Active Plugins (Built-in and Third-Party)
plugins=(
  git
  sudo
  docker
  docker-compose
  golang
  colored-man-pages
  extract
  zsh-autosuggestions
  zsh-syntax-highlighting
  zsh-history-substring-search
  fzf-tab
)

# Initialize Oh-My-Zsh (This automatically sources everything in $ZSH_CUSTOM/*.zsh)
source $ZSH/oh-my-zsh.sh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
