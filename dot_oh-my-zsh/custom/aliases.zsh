# Navigation
alias cd="z"
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# Neovim
alias v="nvim"
alias vi="nvim"
alias vim="nvim"

# Docker / Self-Hosting
alias dps="docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"
alias dco="docker compose"
alias dcup="docker compose up -d"
alias dcdown="docker compose down"
alias dclogs="docker compose logs -f"

# Git Shortcuts
alias gs="git status"
alias gp="git push"
